{
  "version": 2,
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/sync-emails", "schedule": "0 8 * * *" },
    { "path": "/api/ai-analysis", "schedule": "0 9 * * *" }
  ]
}
